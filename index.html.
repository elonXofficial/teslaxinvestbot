        }

        // CONSOLE INTERFACE ENGINE NAVIGATION SWITCH
        function navigateConsole(viewId, element) {
            document.querySelectorAll('.view-pane').forEach(v => v.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            
            document.querySelectorAll('.drawer-link').forEach(i => i.classList.remove('active'));
            if (element) element.classList.add('active');
            
            sideDrawer.classList.remove('open');
            document.body.classList.remove('nav-locked');
            
            if (viewId === 'view-dashboard') loadTradingViewChart(currentActiveTicker);
        }

        function updateFocusSymbol(tickerCode) {
            currentActiveTicker = tickerCode;
            document.getElementById('live-index-title').innerText = `${tickerCode.split(':')[1] || tickerCode} Institutional Analytics`;
            navigateConsole('view-dashboard', document.querySelectorAll('.drawer-link')[0]);
        }

        // TRADING TICKET ROUTINE HANDLERS
        function toggleExecutionTicket(name, cost) {
            selectedProduct = { name: name, cost: cost };
            document.getElementById('order-title-element').innerText = `ORDER EXECUTION TICKET: ${name.toUpperCase()}`;
            document.getElementById('order-form-block').style.display = 'block';
            document.getElementById('products-catalog-container').style.display = 'none';
            document.getElementById('order-form-block').scrollIntoView({ behavior: 'smooth' });
        }

        function refreshGatewayRendering() {
            const mode = document.getElementById('payment-mode-selection').value;
            const qrBlock = document.getElementById('qr-gateway-display-box');
            
            if (mode === 'qr') {
                qrBlock.style.display = 'block';
                document.getElementById('qrcode-target').innerHTML = "";
                qrCodeInstance = new QRCode(document.getElementById("qrcode-target"), {
                    text: "bitcoin:bc1q8egcghdp55c4p54rnw7v4zjwupme7m3se509tw?amount=" + (selectedProduct.cost / 60000).toFixed(4),
                    width: 150, height: 150,
                    colorDark : "#000000", colorLight : "#ffffff"
                });
            } else {
                qrBlock.style.display = 'none';
            }
        }

        async function transmitBrokerPositionOrder() {
            const sizeInput = parseFloat(document.getElementById('order-volume-input').value) || 1;
            const routeMode = document.getElementById('payment-mode-selection').value;
            const currentBal = currentUser ? parseFloat(currentUser.Balance || 0) : 0;
            const aggregateCost = selectedProduct.cost * sizeInput;

            if (sizeInput <= 0) { alert("Execution sizing parameters must evaluate above zero."); return; }

            if (routeMode === 'balance') {
                if (currentBal < aggregateCost) {
                    alert("Order Aborted: Insufficient institutional clearing equity pool allocations.");
                    return;
                }
                const balanceDiff = currentBal - aggregateCost;
                
                if (_supabase && !elonModeActive) {
                    await _supabase.from('Users').update({ Balance: balanceDiff }).eq('telegram_id', currentUser.telegram_id);
                }
                if (currentUser) currentUser.Balance = balanceDiff;
                document.getElementById('balance').innerText = `$${Number(balanceDiff).toLocaleString()}`;
            }

            alert("Clearing confirmation received. Contract metrics dispatched onto processing matrix system.");
            document.getElementById('order-volume-input').value = "1";
            document.getElementById('order-form-block').style.display = 'none';
            document.getElementById('products-catalog-container').style.display = 'block';
        }

        async function executeLiquidityPlacement() {
            const targetVal = parseFloat(document.getElementById('stock-purchase-amount').value) || 0;
            const currentBal = currentUser ? parseFloat(currentUser.Balance || 0) : 0;

            if (targetVal < 5000) { alert("Minimum required routing thresholds mandate values above $5,000."); return; }
            if (targetVal > currentBal) { alert("Execution failed: Assigned parameters breach liquid vault ceilings."); return; }

            const balanceDiff = currentBal - targetVal;
            if (_supabase && !elonModeActive) {
                await _supabase.from('Users').update({ Balance: balanceDiff }).eq('telegram_id', currentUser.telegram_id);
            }
            if (currentUser) currentUser.Balance = balanceDiff;
            document.getElementById('balance').innerText = `$${Number(balanceDiff).toLocaleString()}`;
            
            alert("Market allocation vector finalized securely inside running clusters.");
            document.getElementById('stock-purchase-amount').value = "";
        }

        async function invokeSystemBalanceOverride() {
            const targetId = document.getElementById('admin-target-id').value.trim();
            const targetVal = parseFloat(document.getElementById('admin-target-balance').value);

            if (!targetId || isNaN(targetVal)) { alert("Enter proper data variables before firing master nodes."); return; }
            if (_supabase) {
                const { error } = await _supabase.from('Users').update({ Balance: targetVal }).eq('telegram_id', targetId);
                if (error) alert("Database communication loss: " + error.message);
                else {
                    alert(`Sync Complete. Node account structural record set explicitly to $${targetVal.toLocaleString()}.`);
                    if (currentUser && currentUser.telegram_id === targetId) {
                        currentUser.Balance = targetVal;
                        document.getElementById('balance').innerText = `$${targetVal.toLocaleString()}`;
                    }
                }
            }
        }

        // DEPLOY RUNTIME MATRIX
        async function bootstrapApplicationRuntime() {
            if (tg) { 
                tg.expand(); tg.ready(); 
                if (tg.setHeaderColor) tg.setHeaderColor('secondary_bg_color');
            }
            
            let networkTelegramId = tg?.initDataUnsafe?.user?.id?.toString() || "12345678";
            let fallbackProfileUser = tg?.initDataUnsafe?.user?.username || "FxProMember";

            if (_supabase) {
                let { data: structuralUserRecord } = await _supabase.from('Users').select('*').eq('telegram_id', networkTelegramId).maybeSingle();
                if (!structuralUserRecord) {
                    const { data: initiatedNode } = await _supabase.from('Users').insert([{ telegram_id: networkTelegramId, Name: fallbackProfileUser, Balance: 0 }]).select().maybeSingle();
                    structuralUserRecord = initiatedNode;
                }
                currentUser = structuralUserRecord;
                if (structuralUserRecord) {
                    document.getElementById('user-display').innerText = `@${structuralUserRecord.Name.toUpperCase()}`;
                    document.getElementById('balance').innerText = `$${Number(structuralUserRecord.Balance || 0).toLocaleString()}`;
                }
            }
            
            let verificationAttempts = 0;
            const watchChartFramework = setInterval(() => {
                verificationAttempts++;
                if (window.TradingView) {
                    loadTradingViewChart(currentActiveTicker);
                    clearInterval(watchChartFramework);
                }
                if (verificationAttempts > 35) clearInterval(watchChartFramework);
            }, 200);
        }

        function loadTradingViewChart(ticker) {
            if (window.TradingView && document.getElementById('tradingview_chart')) {
                document.getElementById('tradingview_chart').innerHTML = "";
                new TradingView.widget({
                    "width": "100%", "height": "100%", "symbol": ticker, "interval": "D",
                    "theme": "dark", "style": "1", "locale": "en", "container_id": "tradingview_chart",
                    "hide_side_toolbar": true, "enable_publishing": false
                });
            }
        }

        window.addEventListener('DOMContentLoaded', bootstrapApplicationRuntime);
    </script>
