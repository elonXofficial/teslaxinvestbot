<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>X-Invest Global Advisory</title>
    <!-- Telegram Web App SDK -->
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <!-- Supabase CDN to handle database connection -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --bg-color: #0b0f19;
            --surface-color: #141b2d;
            --accent-color: #00ffcc;
            --text-main: #ffffff;
            --text-muted: #6b7c96;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        header {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            background: linear-gradient(to bottom, rgba(20, 27, 45, 0.5), transparent);
        }

        .logo-area {
            font-size: 20px;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(120deg, #ffffff, var(--text-muted));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 5px;
        }

        .status-badge {
            display: inline-block;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--accent-color);
            background: rgba(0, 255, 204, 0.1);
            padding: 4px 10px;
            border-radius: 20px;
            border: 1px solid rgba(0, 255, 204, 0.2);
        }

        main {
            flex: 1;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
        }

        .balance-card {
            background-color: var(--surface-color);
            border-radius: 16px;
            padding: 24px;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.03);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }

        .balance-label {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 8px;
        }

        .balance-amount {
            font-size: 36px;
            font-weight: 700;
            letter-spacing: -1px;
            color: var(--text-main);
            margin-bottom: 6px;
        }

        .user-info {
            font-size: 11px;
            color: var(--text-muted);
        }

        .grid-menu {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }

        .menu-item {
            background-color: var(--surface-color);
            border: 1px solid rgba(255, 255, 255, 0.03);
            border-radius: 12px;
            padding: 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .menu-icon {
            font-size: 20px;
            width: 36px;
            height: 36px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .menu-title {
            font-size: 14px;
            font-weight: 600;
        }

        .menu-desc {
            font-size: 11px;
            color: var(--text-muted);
        }

        nav {
            background-color: var(--surface-color);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            display: flex;
            justify-content: space-around;
            padding: 10px 0 calc(10px + env(safe-area-inset-bottom, 0px)) 0;
        }

        .nav-link {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 11px;
            width: 20%;
        }

        .nav-link.active {
            color: var(--accent-color);
        }
    </style>
</head>
<body>

    <header>
        <div class="logo-area">X-INVEST GLOBAL</div>
        <div class="status-badge">Live Portfolio Terminal</div>
    </header>

    <main>
        <!-- Real Dynamic Balance Card -->
        <div class="balance-card">
            <div class="balance-label">Your Monitored Balance</div>
            <div id="balance-display" class="balance-amount">Loading...</div>
            <div id="user-display" class="user-info">Connecting to secure link...</div>
        </div>

        <div class="grid-menu">
            <div class="menu-item">
                <div class="menu-icon">📈</div>
                <div class="menu-title">Positions</div>
                <div class="menu-desc">Track active advisory placements.</div>
            </div>
            <div class="menu-item">
                <div class="menu-icon">🛡️</div>
                <div class="menu-title">Security</div>
                <div class="menu-desc">Account protection attributes.</div>
            </div>
        </div>
    </main>

    <nav>
        <a href="#" class="nav-link active"><span>📊 Terminal</span></a>
        <a href="#" class="nav-link"><span>⚙️ Settings</span></a>
    </nav>

    <script>
        // Your real project details are completely locked in below:
        const SUPABASE_URL = "https://uexsmqsplhdxkpuqwzoe.supabase.co";
        const SUPABASE_KEY = "sb_publishable_IysmZmf3VFbXyiefrKprcQ_DYuo_B6W";
        
        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

        // Initialize Telegram WebApp Data
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.ready();

        async function loadUserData() {
            let tgUser = tg.initDataUnsafe?.user;

            // Fallback for computer browser testing
            if (!tgUser) {
                tgUser = { id: 12345, first_name: "Test User", username: "tester" };
            }

            const userId = tgUser.id;
            const firstName = tgUser.first_name;
            const username = tgUser.username || "No Username";

            document.getElementById('user-display').innerText = `ID: ${userId} | Account: ${firstName}`;

            try {
                // Fetch user row from capitalized table 'Users' matching their Telegram ID
                let { data: userRow, error } = await supabase
                    .from('Users')
                    .select('Balance')
                    .eq('telegram_id', userId)
                    .single();

                // If user row doesn't exist yet, automatically insert them with a $0 balance
                if (error && error.code === 'PGRST116') { 
                    const { data: newUser, insertError } = await supabase
                        .from('Users')
                        .insert([{ telegram_id: userId, Name: firstName, Username: username, Balance: 0 }])
                        .select()
                        .single();
                    
                    document.getElementById('balance-display').innerText = "$0.00";
                } else if (userRow) {
                    // Update layout text with the exact Balance specified in your table row
                    document.getElementById('balance-display').innerText = new Intl.NumberFormat('en-US', {
                        style: 'currency',
                        currency: 'USD'
                    }).format(userRow.Balance);
                }
            } catch (err) {
                document.getElementById('balance-display').innerText = "Sync Error";
                console.error(err);
            }
        }

        // Run data check
        loadUserData();
    </script>
</body>
</html>
