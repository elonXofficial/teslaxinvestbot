<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>X-Invest Global Advisory</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        :root {
            --bg-color: #0b0f19;
            --surface-color: #141b2d;
            --accent-color: #00ffcc;
            --text-main: #ffffff;
            --text-muted: #6b7c96;
        }
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }
        header {
            padding: 20px;
            text-align: center;
            background: var(--surface-color);
            border-bottom: 1px solid rgba(0, 255, 204, 0.1);
        }
        .loading-container {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            background: var(--bg-color);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(0, 255, 204, 0.1);
            border-top: 4px solid var(--accent-color);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-bottom: 20px;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        .main-content {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 20px;
            overflow-y: auto;
        }
        .card {
            background: var(--surface-color);
            padding: 20px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            text-align: center;
        }
        .balance-value {
            font-size: 32px;
            font-weight: bold;
            color: var(--accent-color);
            margin-top: 10px;
        }
        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }
    </style>
</head>
<body>

    <div id="loading-screen" class="loading-container">
        <div class="spinner"></div>
        <h2>Loading...</h2>
        <p style="color: var(--text-muted); margin-top: 8px;">Connecting to secure link...</p>
    </div>

    <header>
        <h3>X-INVEST GLOBAL</h3>
        <span style="font-size: 11px; background: rgba(0,255,204,0.1); color: var(--accent-color); padding: 2px 8px; border-radius: 20px; margin-top: 5px; display: inline-block;">LIVE PORTFOLIO TERMINAL</span>
    </header>

    <div class="main-content">
        <div class="card">
            <p style="color: var(--text-muted); font-size: 12px; uppercase;">Your Monitored Balance</p>
            <div id="balance" class="balance-value">$0.00</div>
        </div>

        <div class="grid">
            <div class="card" style="text-align: left;">
                <h4 style="margin-bottom: 5px;">Positions</h4>
                <p style="color: var(--text-muted); font-size: 11px;">Track active advisory placements.</p>
            </div>
            <div class="card" style="text-align: left;">
                <h4 style="margin-bottom: 5px;">Security</h4>
                <p style="color: var(--text-muted); font-size: 11px;">Account protection attributes.</p>
            </div>
        </div>
    </div>

    <script>
        // Initialize Telegram Web App SDK
        const tg = window.Telegram?.WebApp;
        if (tg) {
            tg.expand();
            tg.ready();
        }

        // REPLACE THESE WITH YOUR ACTUAL SUPABASE CREDENTIALS LATER
        const SUPABASE_URL = "https://YOUR_PROJECT_ID.supabase.co";
        const SUPABASE_KEY = "YOUR_ANON_KEY";
        const supabase = window.supabase?.createClient(SUPABASE_URL, SUPABASE_KEY);

        async function initializeApp() {
            try {
                let telegramId = tg?.initDataUnsafe?.user?.id || "12345678";
                let username = tg?.initDataUnsafe?.user?.username || "Guest Trader";

                if (supabase && SUPABASE_URL !== "https://YOUR_PROJECT_ID.supabase.co") {
                    // Try to fetch user profile
                    let { data: user, error } = await supabase
                        .from('Users')
                        .select('*')
                        .eq('telegram_id', telegramId)
                        .maybeSingle();

                    // If empty, dynamically insert a temporary row so it doesn't freeze
                    if (!user) {
                        const { data: newUser } = await supabase
                            .from('Users')
                            .insert([{ telegram_id: telegramId, Name: username }])
                            .select()
                            .maybeSingle();
                        user = newUser;
                    }

                    if (user && user.Balance) {
                        document.getElementById('balance').innerText = `$${Number(user.Balance).toLocaleString()}`;
                    }
                }
            } catch (err) {
                console.error("Database initialization failed:", err);
            } finally {
                // BULLETPROOF FIX: Always close the loading screen no matter what
                setTimeout(() => {
                    document.getElementById('loading-screen').style.display = 'none';
                }, 800);
            }
        }

        window.addEventListener('DOMContentLoaded', initializeApp);
    </script>
</body>
</html>